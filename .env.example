APP_NAME=intelligent-model-router
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

DATABASE_URL=postgresql+asyncpg://router:router@localhost:5432/model_router
DATABASE_URL_SYNC=postgresql://router:router@localhost:5432/model_router

REDIS_URL=redis://localhost:6379/0

# Provider credentials (never commit real values)
PROVIDER_A_API_KEY=
PROVIDER_B_API_KEY=

# Use mock adapters when real keys are absent
USE_MOCK_PROVIDERS=true

DEFAULT_MODEL_ID=model-small
SEED_DEMO_DATA=true
